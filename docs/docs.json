          },
          {
            "group": "Operations",
            "pages": [
              "operations/self-hosting",
              "operations/upgrade",
              "operations/backup",
              "operations/recovery",
              "operations/emergency-cli",
              "operations/troubleshooting",
              "operations/verifying-images",
              "operations/trivy-setup",
              "operations/two-factor-admin"
